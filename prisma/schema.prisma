datasource db {
  provider = "postgresql"
  //url= env("DATABASE_URL")
} 


/* ENUMS */

enum Role {
  ADMIN
  ENGINEER
  INSTITUTION
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  CLOSED
  CANCELED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

/* ENUMS */
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      Role


  institutionId String?
  institution   Institution? @relation("InstitutionUsers", fields: [institutionId], references: [id])

  institutions Institution[] @relation("EngineerInstitutions")

  assignedTickets Ticket[] @relation("AssignedEngineer")

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


/* INSTITUTION */
model Institution {
  id      String @id @default(uuid())
  name    String
  address String
  email   String

  engineerId String
  engineer   User @relation("EngineerInstitutions", fields: [engineerId], references: [id])

  users User[] @relation("InstitutionUsers")

  tickets Ticket[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

/* TICKET */
model Ticket {
  id      String @id @default(uuid())
  number  Int    @unique @default(autoincrement())

  title       String
  description String

  status   TicketStatus @default(NEW)
  priority Priority     @default(NORMAL)

  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  assignedEngineerId String?
  assignedEngineer   User? @relation("AssignedEngineer", fields: [assignedEngineerId], references: [id])

  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedAt  DateTime?
}



/* ARTICLE */
model Article {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  authorId String
 // author   User @relation(fields: [authorId], references: [id])

  body String

  internal Boolean @default(false)

  createdAt DateTime @default(now())
}
